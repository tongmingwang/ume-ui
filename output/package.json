{
  "name": "ume-ui",
  "version": "1.0.3",
  "description": "A Vue 3 component library",
  "type": "module",
  "main": "./dist/ume-ui.cjs.js",
  "module": "./dist/ume-ui.es.js",
  "types": "./dist/ume-ui.es.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ume-ui.es.js",
      "require": "./dist/ume-ui.cjs.js",
      "types": "./dist/ume-ui.es.d.ts"
    },
    "./dist/*.css": "./dist/*.css",
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "vue",
    "vue3",
    "components",
    "ui",
    "component-library"
  ],
  "author": "wangtongming",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tongmingwang/ume-ui.git"
  },
  "homepage": "https://tongmingwang.github.io/ume-ui/",
  "bugs": {
    "url": "https://github.com/tongmingwang/ume-ui/issues"
  }
}
